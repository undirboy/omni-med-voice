# ==================== DUAL-ENGINE AI MATRIX ====================
class OmniMedAIVision:
    def __init__(self):
        self.mp_holistic = mp.solutions.holistic
        self.tracker = self.mp_holistic.Holistic(min_detection_confidence=0.5, min_tracking_confidence=0.5, refine_face_landmarks=False)
        self.mp_draw = mp.solutions.drawing_utils
        self.pose_spec = self.mp_draw.DrawingSpec(color=(0, 210, 255), thickness=2, circle_radius=2)
        self.hand_spec = self.mp_draw.DrawingSpec(color=(0, 255, 118), thickness=1, circle_radius=2)
        
        self.mp_face_detection = mp.solutions.face_detection
        self.face_detector = self.mp_face_detection.FaceDetection(model_selection=1, min_detection_confidence=0.5)

        self.timers = {"NURSE_CALL": None, "HEAD_DISTRESS": None, "BREATHING_DISTRESS": None, "CHEST_DISTRESS": None, "FALL_COLLAPSE": None}
        self.previous_joints = None

    def draw_zone(self, frame, x1, y1, x2, y2, label):
        cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 255, 100), 1)
        cv2.putText(frame, label, (x1, y1-5), cv2.FONT_HERSHEY_SIMPLEX, 0.4, (0, 255, 100), 1)

    def run_engine(self, cap):
        global latest_processed_frame, raw_camera_frame, is_system_running
        
        while is_system_running:
            with frame_lock:
                if raw_camera_frame is None: time.sleep(0.01); continue
                frame = raw_camera_frame.copy()

            frame = cv2.flip(frame, 1); h, w, c = frame.shape
            rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            current_time = time.time()
            
            active_gesture = "NONE"
            lock_progress = 0
            
            # --- ROOM RADAR ---
            face_res = self.face_detector.process(rgb_frame)
            occupancy = 0
            if face_res.detections:
                occupancy = len(face_res.detections)
                for i, detection in enumerate(face_res.detections):
                    bboxC = detection.location_data.relative_bounding_box
                    x, y, w_box, h_box = int(bboxC.xmin * w), int(bboxC.ymin * h), int(bboxC.width * w), int(bboxC.height * h)
                    cv2.rectangle(frame, (x, y), (x+w_box, y+h_box), (0, 255, 100), 1)
                    cv2.putText(frame, f"TARGET_{i+1}", (x, y-10), cv2.FONT_HERSHEY_SIMPLEX, 0.4, (0, 255, 100), 1)
            LIVE_TELEMETRY["room_occupancy"] = occupancy

            # --- DEEP BIOMETRICS ---
            results = self.tracker.process(rgb_frame)

            if results.left_hand_landmarks: self.mp_draw.draw_landmarks(frame, results.left_hand_landmarks, self.mp_holistic.HAND_CONNECTIONS, self.hand_spec, self.hand_spec)
            if results.right_hand_landmarks: self.mp_draw.draw_landmarks(frame, results.right_hand_landmarks, self.mp_holistic.HAND_CONNECTIONS, self.hand_spec, self.hand_spec)

            if results.pose_landmarks:
                self.mp_draw.draw_landmarks(frame, results.pose_landmarks, self.mp_holistic.POSE_CONNECTIONS, self.pose_spec, self.pose_spec)
                nodes = results.pose_landmarks.landmark
                try:
                    nose = nodes[0]; l_eye = nodes[2]; r_eye = nodes[5]; l_mouth = nodes[9]; r_mouth = nodes[10]
                    l_sh = nodes[11]; r_sh = nodes[12]; l_hip = nodes[23]; r_hip = nodes[24]
                    l_wrist = nodes[15]; r_wrist = nodes[16]

                    nose_y = nose.y * h
                    eye_y = ((l_eye.y + r_eye.y) / 2) * h
                    mouth_y = ((l_mouth.y + r_mouth.y) / 2) * h
                    
                    head_top_y = int(eye_y - abs(mouth_y - eye_y) * 1.5)
                    chin_y = int(mouth_y)
                    shoulder_y = int(((l_sh.y + r_sh.y) / 2) * h)
                    hip_y = int(((l_hip.y + r_hip.y) / 2) * h)
                    chest_bottom_y = int(shoulder_y + (hip_y - shoulder_y) * 0.5)

                    avg_sh_x = ((l_sh.x + r_sh.x) / 2) * w
                    shoulder_w = abs(l_sh.x - r_sh.x) * w
                    zone_x1 = int(avg_sh_x - shoulder_w * 0.6)
                    zone_x2 = int(avg_sh_x + shoulder_w * 0.6)

                    self.draw_zone(frame, zone_x1, head_top_y, zone_x2, chin_y, "HEAD ZONE")
                    self.draw_zone(frame, zone_x1, chin_y, zone_x2, shoulder_y, "BREATHING ZONE")
                    self.draw_zone(frame, zone_x1, shoulder_y, zone_x2, chest_bottom_y, "CHEST ZONE")

                    angle = int(math.degrees(math.atan2(abs(avg_sh_x - ((l_hip.x + r_hip.x)/2 * w)), abs(hip_y - shoulder_y))))
                    LIVE_TELEMETRY["posture_angle"] = angle

                    curr_joints = np.array([[n.x, n.y] for n in [nose, l_sh, r_sh, l_wrist, r_wrist]])
                    if self.previous_joints is not None:
                        delta = np.sum(np.abs(curr_joints - self.previous_joints))
                        LIVE_TELEMETRY["kinetic_activity"] = min(100, int(delta * 1200))
                    self.previous_joints = curr_joints

                    l_y, r_y = l_wrist.y * h, r_wrist.y * h
                    l_x, r_x = l_wrist.x * w, r_wrist.x * w
                    
                    is_central_l = zone_x1 < l_x < zone_x2
                    is_central_r = zone_x1 < r_x < zone_x2

                    is_nurse = (l_y < head_top_y) or (r_y < head_top_y)
                    is_head = (not is_nurse) and ((head_top_y <= l_y < chin_y and is_central_l) or (head_top_y <= r_y < chin_y and is_central_r))
                    is_breathing = (not is_nurse and not is_head) and ((chin_y <= l_y < shoulder_y and is_central_l) or (chin_y <= r_y < shoulder_y and is_central_r))
                    is_chest = (not is_nurse and not is_head and not is_breathing) and ((shoulder_y <= l_y < chest_bottom_y and is_central_l) or (shoulder_y <= r_y < chest_bottom_y and is_central_r))

                    is_falling = angle > 65

                    if is_breathing or is_falling: LIVE_TELEMETRY["spo2_level"] = max(82, LIVE_TELEMETRY["spo2_level"] - 1)
                    else: LIVE_TELEMETRY["spo2_level"] = min(99, LIVE_TELEMETRY["spo2_level"] + 1)
                    if LIVE_TELEMETRY["spo2_level"] < 90:
                        with database_lock:
                            if not LIVE_TRIAGE_ALARMS["HYPOXIA_ALERT"]["active"] and not LIVE_TRIAGE_ALARMS["HYPOXIA_ALERT"]["acknowledged"]:
                                LIVE_TRIAGE_ALARMS["HYPOXIA_ALERT"]["active"] = True
                                speak_notification(LIVE_TRIAGE_ALARMS["HYPOXIA_ALERT"]["spoken_alert"])

                    def process_gesture(key, condition, req_time=3.0):
                        nonlocal active_gesture, lock_progress
                        if condition and not LIVE_TRIAGE_ALARMS[key]["active"]:
                            if self.timers[key] is None: self.timers[key] = current_time
                            elapsed = current_time - self.timers[key]
                            active_gesture = key
                            lock_progress = min(100, int((elapsed / req_time) * 100))
                            
                            cv2.circle(frame, (w//2, h//2), 80, (0,0,255), -1)
                            cv2.circle(frame, (w//2, h//2), int(80*(elapsed/req_time)), (0,240,255), 4)
                            cv2.putText(frame, f"LOCKING: {req_time-elapsed:.1f}s", (w//2 - 60, h//2 + 5), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (255,255,255), 2)
                            
                            if elapsed >= req_time:
                                with database_lock:
                                    LIVE_TRIAGE_ALARMS[key]["active"] = True
                                    LIVE_TRIAGE_ALARMS[key]["acknowledged"] = False
                                    CHAT_MESSAGES.append({"time": time.strftime('%H:%M:%S'), "sender": "SYSTEM", "target": "ALL", "msg": f"CRITICAL ALARM: {key.replace('_', ' ')} DETECTED!"})
                                    LATEST_EVENTS["alarm"] += 1
                                    speak_notification(LIVE_TRIAGE_ALARMS[key]["spoken_alert"])
                                self.timers[key] = None
                        else:
                            if self.timers[key] is not None:
                                self.timers[key] = None

                    if is_falling: process_gesture("FALL_COLLAPSE", is_falling)
                    elif is_chest: process_gesture("CHEST_DISTRESS", is_chest)
                    elif is_breathing: process_gesture("BREATHING_DISTRESS", is_breathing)
                    elif is_head: process_gesture("HEAD_DISTRESS", is_head)
                    elif is_nurse: process_gesture("NURSE_CALL", is_nurse, 2.0)
                    else:
                        for k in self.timers.keys(): self.timers[k] = None

                except Exception as e: pass

            LIVE_TELEMETRY["ai_locking_on"] = active_gesture
            LIVE_TELEMETRY["ai_lock_progress"] = lock_progress

            cv2.putText(frame, "OMNIMED MULTI-NODE SENSORS ACTIVE.", (20, 30), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 210, 255), 2)
            
            with frame_lock: latest_processed_frame = frame.copy()
            cv2.imshow("OMNIMED ENGINE", frame)

            key = cv2.waitKey(1) & 0xFF
            if key == ord('q'): is_system_running = False; break

        self.tracker.close()
        self.face_detector.close()
        cap.release(); cv2.destroyAllWindows()

if __name__ == "__main__":
    is_system_running = True
    
    if sys.platform == "win32":
        hardware_video_capture = cv2.VideoCapture(0, cv2.CAP_DSHOW)
    else:
        hardware_video_capture = cv2.VideoCapture(0)
        
    hardware_video_capture.set(cv2.CAP_PROP_FRAME_WIDTH, 1280)
    hardware_video_capture.set(cv2.CAP_PROP_FRAME_HEIGHT, 720)
    
    threading.Thread(target=hardware_buffer_cleaner, args=(hardware_video_capture,), daemon=True).start()
    threading.Thread(target=launch_server, daemon=True).start()
    threading.Thread(target=voice_recognition_worker, daemon=True).start()
    
    ai_engine = OmniMedAIVision()
    ai_engine.run_engine(hardware_video_capture)
