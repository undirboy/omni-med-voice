                let osc = audioCtx.createOscillator();
                let gain = audioCtx.createGain();
                if(type === 'msg') { osc.frequency.setValueAtTime(600, audioCtx.currentTime); osc.type = 'sine'; }
                else if(type === 'alarm') { osc.frequency.setValueAtTime(400, audioCtx.currentTime); osc.type = 'sawtooth'; }
                gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.3);
                osc.connect(gain); gain.connect(audioCtx.destination);
                osc.start(); osc.stop(audioCtx.currentTime + 0.3);
            } catch(e){}
        }

        function startSiren() {
            try {
                if(!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                if(!sirenOsc) {
                    sirenOsc = audioCtx.createOscillator();
                    let gain = audioCtx.createGain();
                    sirenOsc.type = 'square';
                    sirenOsc.frequency.setValueAtTime(800, audioCtx.currentTime);
                    setInterval(() => {
                        if(sirenOsc) { sirenOsc.frequency.setValueAtTime(900, audioCtx.currentTime); sirenOsc.frequency.setValueAtTime(700, audioCtx.currentTime + 0.25); }
                    }, 500);
                    gain.gain.value = 0.05;
                    sirenOsc.connect(gain); gain.connect(audioCtx.destination);
                    sirenOsc.start();
                }
            } catch(e){}
        }

        function stopSiren() {
            if(sirenOsc) { sirenOsc.stop(); sirenOsc.disconnect(); sirenOsc = null; }
