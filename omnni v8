# 2. DECLARATIVE DATA-DRIVEN RULE ENGINE
# ==========================================================
# Rules are now structured completely as declarative data profiles, not compiled python code
DECLARATIVE_RULES_JSON = """
[
    {
        "rule_name": "Critical_Fall_Distress",
        "conditions": {
            "fall_detected": true,
            "shout_detected": true
        },
        "target_state": "ALERTING",
        "priority_threshold": 90
    },
    {
        "rule_name": "Sustained_Symptom_Hold",
        "conditions": {
            "chest_hold": true
        },
        "target_state": "VERIFYING",
        "priority_threshold": 60
    }
]
"""

class FactRuleEngine:
    """Evaluates runtime sensor facts against clinical rule data files."""
    def __init__(self, rules_json: str):
        self.rules = json.loads(rules_json)

    def evaluate(self, current_facts: Dict[str, TelemetryEvent]) -> Optional[str]:
        # Process high priority rule matches first
        sorted_rules = sorted(self.rules, key=lambda x: x["priority_threshold"], reverse=True)
        
        for rule in sorted_rules:
            match = True
            for condition_key, expected_val in rule["conditions"].items():
                fact = current_facts.get(condition_key)
                if not fact or fact.value != expected_val:
                    match = False
                    break
            if match:
                return rule["target_state"]
        return None

# ==========================================================
# 3. STATE PERSISTENCE RECOVERY LAYER
# ==========================================================
class StatePersistenceLayer:
    """Guards system tracking integrity against power interruptions."""
    def __init__(self, filepath: str = "omnimed_state_nvram.json"):
        self.filepath = filepath

    def persist(self, state_name: str, active_events: Dict[str, Any]):
        try:
            payload = {
                "current_state": state_name,
                "timestamp": time.time(),
                "events_serialized": {k: v.value for k, v in active_events.items()}
            }
            with open(self.filepath, "w") as f:
                json.dump(payload, f)
        except Exception as e:
            logging.error(f"Persistence error: {e}")

    def recover_last_state(self) -> Optional[str]:
        if os.path.exists(self.filepath):
            try:
                with open(self.filepath, "r") as f:
                    data = json.load(f)
                # Verify age bounds before restoring state (e.g., within 5 minutes)
                if time.time() - data["timestamp"] < 300.0:
                    return data["current_state"]
            except Exception:
                pass
        return None

# ==========================================================
# 4. DECOUPLED COMMAND ACTUATION PIPELINES
# ==========================================================
class ICommand(abc.ABC):
    @abc.abstractmethod
    def execute(self) -> None: ...

class DispatchSirenCommand(ICommand):
    def execute(self): print("🚨 [ACTUATION] Siren command sent to hardware relays.")

class NotifyCaregiverCommand(ICommand):
    def execute(self): print("📧 [ACTUATION] Pushing emergency telemetry payloads to nurse station.")

class CommandDispatcher:
    """Manages command queues independently from the main state machine."""
    def __init__(self):
        self.command_queue: List[ICommand] = []

    def dispatch(self, command: ICommand):
        self.command_queue.append(command)
        command.execute() # Executes immediately or pipes down a bounded hardware thread pool

# ==========================================================
# 5. EXPLICIT FINITE STATE MACHINE (FSM)
# ==========================================================
class FSMContext:
    def __init__(self, rule_engine: FactRuleEngine, dispatcher: CommandDispatcher, persistence: StatePersistenceLayer):
        self.rule_engine = rule_engine
        self.dispatcher = dispatcher
        self.persistence = persistence
        self.state_entered_time = time.time()

class FSMState(abc.ABC):
    def __init__(self, name: str):
        self.name = name
    def on_entry(self, ctx: FSMContext): pass
    def on_exit(self, ctx: FSMContext): pass
    @abc.abstractmethod
    def run_logic(self, ctx: FSMContext, facts: Dict[str, TelemetryEvent]) -> str: ...

class NormalState(FSMState):
    def __init__(self): super().__init__("NORMAL")
    def run_logic(self, ctx: FSMContext, facts: Dict[str, TelemetryEvent]) -> str:
        matched_state = ctx.rule_engine.evaluate(facts)
        return matched_state if matched_state else "NORMAL"

class VerifyingState(FSMState):
    def __init__(self): super().__init__("VERIFYING")
    def on_entry(self, ctx: FSMContext):
        print("🗣️  [AUDIO PROMPT] System Query: Please state if you require medical assistance.")
        
    def run_logic(self, ctx: FSMContext, facts: Dict[str, TelemetryEvent]) -> str:
        voice = facts.get("keyword_matched")
        if voice and voice.value and voice.priority == Priority.CRITICAL:
            return "ALERTING"
        if time.time() - ctx.state_entered_time > 5.0: # Time-bounded transition rule
            return "ALERTING"
        return "VERIFYING"

class AlertingState(FSMState):
    def __init__(self): super().__init__("ALERTING")
    def on_entry(self, ctx: FSMContext):
        # Fire commands through the command pattern system rather than running actions directly
        ctx.dispatcher.dispatch(DispatchSirenCommand())
        ctx.dispatcher.dispatch(NotifyCaregiverCommand())
        
    def run_logic(self, ctx: FSMContext, facts: Dict[str, TelemetryEvent]) -> str:
        return "WAITING_FOR_ACK"

class WaitingForAckState(FSMState):
    def __init__(self): super().__init__("WAITING_FOR_ACK")
    def run_logic(self, ctx: FSMContext, facts: Dict[str, TelemetryEvent]) -> str:
        return "WAITING_FOR_ACK"

# ==========================================================
# 6. APPLICATION SYSTEM CORE ENGINE
# ==========================================================
class OmniMedEngineCore:
    def __init__(self, rule_engine: FactRuleEngine, dispatcher: CommandDispatcher, persistence: StatePersistenceLayer):
        self.latest_state_registry: Dict[str, TelemetryEvent] = {}
        self.dispatcher = dispatcher
        self.persistence = persistence
        
        self.states_map: Dict[str, FSMState] = {
            "NORMAL": NormalState(),
            "VERIFYING": VerifyingState(),
            "ALERTING": AlertingState(),
            "WAITING_FOR_ACK": WaitingForAckState()
        }
        
        # Check NVRAM persistence mapping before assigning initialization bounds
        recovered_state = self.persistence.recover_last_state()
        initial_state_key = recovered_state if recovered_state in self.states_map else "NORMAL"
        
        self.current_state = self.states_map[initial_state_key]
        self.fsm_context = FSMContext(rule_engine, dispatcher, persistence)
        
        if recovered_state:
            logging.info(f"System recovered safely from crash state back into: [{initial_state_key}]")

    def update_fact(self, event: TelemetryEvent):
        """Processes and stores incoming tracking updates."""
        self.latest_state_registry[event.source] = event

    def process_system_tick(self):
        """Deterministic tracking execution tick."""
        # 1. Compute state tracking rules matrix mutations
        next_state_name = self.current_state.run_logic(self.fsm_context, self.latest_state_registry)
        
        # 2. Handle State Transitions cleanly
        if next_state_name != self.current_state.name:
            self.current_state.on_exit(self.fsm_context)
            self.current_state = self.states_map[next_state_name]
            self.fsm_context = FSMContext(self.fsm_context.rule_engine, self.dispatcher, self.persistence)
            self.current_state.on_entry(self.fsm_context)
            
            # Persist state directly to simulated non-volatile storage bounds
            self.persistence.persist(self.current_state.name, self.latest_state_registry)

