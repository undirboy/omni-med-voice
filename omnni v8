class HealthState(Enum):
    HEALTHY = auto()
    DEGRADED = auto()
    FAILED = auto()
    RECOVERING = auto()

class Priority(Enum):
    LOW = 10
    MEDIUM = 60
    HIGH = 90
    CRITICAL = 100

@dataclass(frozen=True)
class TelemetryEvent:
    event_id: int
    timestamp: float
    source: str
    value: bool
    confidence: float
    priority: Priority
    latency_ms: float
    quality: str  # "GOOD", "MARGINAL", "POOR"
    metadata: Dict[str, Any] = field(default_factory=dict)

