class PatientKalmanFilter:
    def __init__(self, init_x, init_y):
        self.X = np.array([[init_x], [init_y], [0.0], [0.0]], dtype=np.float32)
        self.F = np.array([[1, 0, 1, 0], [0, 1, 0, 1], [0, 0, 1, 0], [0, 0, 0, 1]], dtype=np.float32)
        self.H = np.array([[1, 0, 0, 0], [0, 1, 0, 0]], dtype=np.float32)
        self.P = np.eye(4, dtype=np.float32) * 15.0
        self.Q = np.eye(4, dtype=np.float32) * 0.2
        self.R = np.eye(2, dtype=np.float32) * 3.0

    def predict(self):
        self.X = np.dot(self.F, self.X)
        self.P = np.dot(np.dot(self.F, self.P), self.F.T) + self.Q
        return float(self.X[0, 0]), float(self.X[1, 0])

    def correct(self, meas_x, meas_y):
        Z = np.array([[meas_x], [meas_y]], dtype=np.float32)
        y_residual = Z - np.dot(self.H, self.X)
        S = np.dot(np.dot(self.H, self.P), self.H.T) + self.R
        K = np.dot(np.dot(self.P, self.H.T), np.linalg.inv(S))
        self.X = self.X + np.dot(K, y_residual)
        self.P = np.dot((np.eye(4, dtype=np.float32) - np.dot(K, self.H)), self.P)

