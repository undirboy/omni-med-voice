class BayesianFusionEngine:
    @staticmethod
    def evaluate_emergency_posterior(gesture_conf, audio_conf, sqi_factor):
        p_e = SYSTEM_CONFIG["FUSION"]["PRIOR_EMERGENCY"]
        p_not_e = 1.0 - p_e
        
        sqi_scaled_p_g_e = 0.5 + (SYSTEM_CONFIG["FUSION"]["P_G_GIVEN_E"] - 0.5) * (sqi_factor / 100.0)
        
        # Accounts for conditional coupling: if high audio panic matches continuous gesture, amplify likelihood scaling
        coupling_modifier = 1.25 if (gesture_conf > 0.8 and audio_conf > 0.8) else 1.0
        
        p_obs_given_e = (sqi_scaled_p_g_e if gesture_conf > 0.7 else (1.0 - sqi_scaled_p_g_e)) * \
                        (SYSTEM_CONFIG["FUSION"]["P_A_GIVEN_E"] if audio_conf > 0.5 else (1.0 - SYSTEM_CONFIG["FUSION"]["P_A_GIVEN_E"])) * coupling_modifier
        p_obs_given_e = min(p_obs_given_e, 1.0)

        p_obs_given_not_e = (SYSTEM_CONFIG["FUSION"]["P_G_GIVEN_NOT_E"] if gesture_conf > 0.7 else (1.0 - SYSTEM_CONFIG["FUSION"]["P_G_GIVEN_NOT_E"])) * \
                            (SYSTEM_CONFIG["FUSION"]["P_A_GIVEN_NOT_E"] if audio_conf > 0.5 else (1.0 - SYSTEM_CONFIG["FUSION"]["P_A_GIVEN_NOT_E"]))

        numerator = p_obs_given_e * p_e
        denominator = numerator + (p_obs_given_not_e * p_not_e)
        return numerator / denominator if denominator > 0 else 0.0

class SystemState:
    def __init__(self):
        self.lock = threading.Lock()
        self.amplitude = 0
        self.last_audio_event = "NONE"
        self.last_audio_ts = 0.0

    def update_audio(self, amplitude):
        with self.lock: self.amplitude = amplitude

    def get_audio_amplitude(self):
        with self.lock: return self.amplitude

    def log_keyword(self, keyword, timestamp):
        with self.lock:
            self.last_audio_event = keyword
            self.last_audio_ts = timestamp
            
    def get_last_keyword_data(self):
        with self.lock: return self.last_audio_event, self.last_audio_ts

