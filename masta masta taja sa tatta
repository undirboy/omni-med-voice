class FlightDataRecorder:
    def __init__(self, rotation_threshold=5000):
        self.base_filename = f"omnimed_session_{int(time.time())}"
        self.current_log_path = f"{self.base_filename}.jsonl"
        self.file = open(self.current_log_path, 'a', encoding='utf-8')
        self.lock = threading.Lock()
        self.last_flush = time.monotonic()
        self.record_count = 0
        self.rotation_threshold = rotation_threshold
        logger.info(f"Flight Data Recorder active: {self.current_log_path}")

    def log_telemetry(self, telemetry_dict):
        with self.lock:
            telemetry_dict["sys_time"] = time.time()
            self.file.write(json.dumps(telemetry_dict) + "\n")
            self.record_count += 1
            
            if time.monotonic() - self.last_flush >= 1.0:
                self.file.flush()
                self.last_flush = time.monotonic()
                
            if self.record_count >= self.rotation_threshold:
                self._rotate_and_compress()

    def _rotate_and_compress(self):
        self.file.flush()
        self.file.close()
        archive_name = f"{self.base_filename}_chunk_{int(time.time())}.jsonl.gz"
        try:
            with open(self.current_log_path, 'rb') as f_in:
                with gzip.open(archive_name, 'wb') as f_out:
                    f_out.writelines(f_in)
            logger.info(f"Telemetry log chunk compressed out safely to: {archive_name}")
        except Exception as e:
            logger.error(f"Failed to compress telemetry record log: {e}")
        
        self.file = open(self.current_log_path, 'w', encoding='utf-8')
        self.record_count = 0

    def close(self):
        with self.lock:
            if not self.file.closed:
                self.file.flush()
                self.file.close()

class PersistentDatabaseWorker(threading.Thread):
    def __init__(self, db_path="cloud_queue.db"):
        super().__init__(name="DatabaseWorker", daemon=True)
        self.db_path = db_path
        self.task_queue = queue.Queue()
        self.shutdown_event = threading.Event()
        self.connected_event = threading.Event()
        self._init_db()

    def _init_db(self):
        conn = sqlite3.connect(self.db_path)
        conn.execute("PRAGMA journal_mode=WAL;")
        conn.execute("PRAGMA synchronous=NORMAL;")
        conn.execute("CREATE TABLE IF NOT EXISTS queue (id INTEGER PRIMARY KEY, tier INTEGER, ts REAL, payload TEXT)")
        conn.commit()
        conn.close()

    def run(self):
        conn = sqlite3.connect(self.db_path)
        conn.execute("PRAGMA journal_mode=WAL;")
        conn.execute("PRAGMA synchronous=NORMAL;")
        self.connected_event.set()
        
        while not self.shutdown_event.is_set() or not self.task_queue.empty():
            try:
                task = self.task_queue.get(timeout=0.5)
                task_type, data = task
                if task_type == "INSERT":
                    tier, ts, payload = data
                    conn.execute("INSERT INTO queue (tier, ts, payload) VALUES (?, ?, ?)", (tier, ts, payload))
                    conn.commit()
                elif task_type == "DELETE":
                    item_id = data
                    conn.execute("DELETE FROM queue WHERE id=?", (item_id,))
                    conn.commit()
                self.task_queue.task_done()
            except queue.Empty:
                continue
            except Exception as e:
                logger.error(f"SQLite transactional worker internal failure: {e}")
        conn.close()

    def put_async(self, tier, ts, payload):
        self.task_queue.put(("INSERT", (tier, ts, payload)))

    def delete_async(self, item_id):
        self.task_queue.put(("DELETE", item_id))

    def fetch_highest_priority(self):
        conn = sqlite3.connect(self.db_path)
        cur = conn.execute("SELECT id, tier, ts, payload FROM queue ORDER BY tier ASC, ts ASC LIMIT 1")
        row = cur.fetchone()
        conn.close()
        return row

class StratifiedStrictPriorityQueue:
    def __init__(self):
        self.tiers = {1: [], 2: [], 3: []} 
        self.lock = threading.Lock()
        self.condition = threading.Condition(self.lock)

    def put(self, tier, payload):
        if tier not in self.tiers:
            tier = 3
        with self.condition:
            self.tiers[tier].append((time.monotonic(), payload))
            self.condition.notify()

    def get(self, timeout=2.0):
        with self.condition:
            start_time = time.monotonic()
            while True:
                for tier in sorted(self.tiers.keys()):
                    if self.tiers[tier]:
                        return tier, self.tiers[tier].pop(0)[1]
                elapsed = time.monotonic() - start_time
                remaining = timeout - elapsed
                if remaining <= 0 or not self.condition.wait(remaining):
                    raise queue.Empty

