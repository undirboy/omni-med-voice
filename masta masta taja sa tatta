                    engine.runAndWait() 
                except queue.Empty:
                    continue
        except Exception as e:
            logger.exception(f"Fatal disruption in TTS subsystem processing: {e}")

    def _cloud_worker_loop(self):
        logger.info("Persistent Network Dispatch Engine active.")
        url = f"https://ntfy.sh/{SYSTEM_CONFIG['NETWORK']['NTFY_TOPIC']}"
        headers = {"Title": "OMNIMED RADICAL MATRIX ALERT", "Priority": "high", "Tags": "critical"}
        
        while not self.shutdown_event.is_set():
            try:
                row = self.db_worker.fetch_highest_priority()
                if not row:
                    self.shutdown_event.wait(1.0)
                    continue
                db_id, tier, ts, payload = row
                
                success = False
                for attempt in range(SYSTEM_CONFIG["NETWORK"]["MAX_RETRIES"]):
                    if self.shutdown_event.is_set(): break
                    try:
                        resp = requests.post(url, data=payload.encode('utf-8'), headers=headers, timeout=SYSTEM_CONFIG["NETWORK"]["TIMEOUT"])
                        if resp.status_code == 200: 
                            success = True
                            break
                    except Exception as e:
                        logger.warning(f"Cloud network packet dropped. Retrying context frame: {e}")
                    time.sleep(0.5 * (2 ** attempt))
                    
                if success:
                    self.db_worker.delete_async(db_id)
                else:
                    logger.error(f"Cloud transaction failed permanently. Relocating payload to DLQ: {db_id}")
                    try: self.dead_letter_queue.put_nowait((tier, ts, payload))
                    except queue.Full: pass
                    self.db_worker.delete_async(db_id) 
            except Exception as e:
                logger.error(f"Cloud dispatcher execution tracking failure: {e}")
                self.shutdown_event.wait(1.0)

    def dispatch_alert(self, tier_level, message, cloud_payload):
        self.tts_queue.put(tier_level, message)
        self.db_worker.put_async(tier_level, time.time(), cloud_payload)

    # ==================== DECOUPLED INGESTION CHANNELS ====================

    def _camera_capture_loop(self):
        backend = cv2.CAP_ANY
        if sys.platform.startswith('win'): backend = cv2.CAP_DSHOW
        elif sys.platform.startswith('darwin'): backend = cv2.CAP_AVFOUNDATION
        elif sys.platform.startswith('linux'): backend = cv2.CAP_V4L2
            
        cap = cv2.VideoCapture(0, backend) 
        cap.set(cv2.CAP_PROP_FRAME_WIDTH, SYSTEM_CONFIG["VISION"]["FRAME_WIDTH"])
        cap.set(cv2.CAP_PROP_FRAME_HEIGHT, SYSTEM_CONFIG["VISION"]["FRAME_HEIGHT"])
        
        while not self.shutdown_event.is_set():
            ret, frame = cap.read()
            if not ret:
                time.sleep(0.01)
                continue
            
            meta = FrameMetadata()
            meta.queue_entry_time = time.monotonic()
            
            try:
                self.frame_queue.put_nowait((cv2.flip(frame, 1), meta))
            except queue.Full:
                try:
                    self.frame_queue.get_nowait() 
                    self.frame_queue.put_nowait((cv2.flip(frame, 1), meta))
                except queue.Empty:
                    pass
        cap.release()

    def _audio_engine_loop(self):
        try:
            stream = self.pa_engine.open(format=pyaudio.paInt16, channels=1, rate=16000, input=True, frames_per_buffer=1024)
        except Exception as e:
            logger.exception(f"Acoustic hardware interface mapping failure: {e}")
            return
        
        while not self.shutdown_event.is_set():
            try:
                data = stream.read(1024, exception_on_overflow=False)
                if not data: continue
                raw_buffer = np.frombuffer(data, dtype=np.int16)
                if len(raw_buffer) > 0:
                    rms = int(np.sqrt(np.mean(raw_buffer.astype(np.float32)**2)))
                    final_amp = rms
                    
                    if rms > SYSTEM_CONFIG["AUDIO"]["SCREAM_RMS_THRESHOLD"]:
                        fft_vals = np.abs(np.fft.rfft(raw_buffer))
                        if np.sum(fft_vals[self.scream_band_idx]) <= np.sum(fft_vals[self.ambient_band_idx]) * 0.4:
                            final_amp = int(rms * 0.1) 
                            
                    self.state.update_audio(final_amp)
                    
                    if rms > SYSTEM_CONFIG["AUDIO"]["VAD_RMS_THRESHOLD"]:
                        with self.memory_lock:
                            if len(self.raw_audio_queue) >= self.raw_audio_queue.maxlen - 5:
                                logger.warning("Acoustic linguistic parsing queue saturation detected. Audio dropped.")
                            self.raw_audio_queue.append(data)
            except Exception as e:
                logger.error(f"Audio stream interception crash: {e}")
        stream.stop_stream()
        stream.close()

    def _speech_pipeline_loop(self):
        if self.vosk_model is None: return
        recognizer = KaldiRecognizer(self.vosk_model, 16000)
        while not self.shutdown_event.is_set():
            if len(self.raw_audio_queue) < 8:
                self.shutdown_event.wait(0.1)
                continue
            
            audio_chunks = []
            with self.memory_lock:
                while self.raw_audio_queue: 
                    audio_chunks.append(self.raw_audio_queue.popleft())
                
            if recognizer.AcceptWaveform(b"".join(audio_chunks)):
                raw_text = json.loads(recognizer.Result()).get("text", "").lower()
                if raw_text.strip():
                    now_mono = time.monotonic()
                    with self.memory_lock: 
                        self.audio_sentence_window.append((raw_text, now_mono))
                    
                    while self.audio_sentence_window and (now_mono - self.audio_sentence_window[0][1] > SYSTEM_CONFIG["AUDIO"]["AUDIO_WINDOW_TIMEOUT_SECS"]):
                        self.audio_sentence_window.popleft()

                    combined = " ".join([token[0] for token in self.audio_sentence_window])
                    for kw in sorted(self.PANIC_KEYWORDS, key=len, reverse=True):
                        if kw in combined:
                            ts = time.time()
                            last_kw, last_ts = self.state.get_last_keyword_data()
                            if last_kw != kw.upper() or (ts - last_ts > 5.0):
                                self.state.log_keyword(kw.upper(), ts)
                                action = self.EMERGENCY_DATABASE[kw]
                                self.dispatch_alert(action.priority, action.spoken_alert, f"Acoustic Alert Matrix [{action.network_tag}]: '{kw.upper()}'")
                            break

